{
  "name": "csr-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Shared backend for the CSR Training Management System (Public Website, Admin, Manager, Trainer, Candidate portals).",
  "main": "dist/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "seed": "tsx src/seed/seed.ts",
    "smoke:models": "tsx scripts/smoke-test.ts",
    "smoke:http": "tsx scripts/smoke-http.ts",
    "smoke:flow": "tsx scripts/smoke-http2.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.5.3",
    "morgan": "^1.10.0",
    "multer": "^2.2.0",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.4",
    "resend": "^6.17.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.2.0",
    "@types/node": "^20.14.15",
    "@types/qrcode": "^1.5.6",
    "mongodb-memory-server": "^11.2.0",
    "tsx": "^4.16.5",
    "typescript": "^5.5.4"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "mongodb-memory-server@11.2.0": true
  }
}
